---
interface Props {
  title: string;
  description?: string;
  /** Theme — controls mobile browser chrome color. Defaults to solo (burgundy). */
  theme?: 'solo' | 'dial';
  /** og:type. `article` for content pieces, `website` for index pages. */
  ogType?: 'article' | 'website';
  /** Override for og:image:alt; otherwise auto-derived from the title. */
  imageAlt?: string;
  /** Frontmatter date string (e.g. "January 3, 2023") for content pages. */
  published?: string;
  /** Display author name for article:author. */
  author?: string;
}
const {
  title,
  description = 'Maxine Levesque',
  theme = 'solo',
  ogType = 'website',
  imageAlt,
  published,
  author,
} = Astro.props;

const SITE = "Maxine's dream machine";
const pageTitle = title === SITE ? title : `${title} — ${SITE}`;

// Per-page OG image: mirrors the URL path under /og/, with the home page
// using /og/home.png. Resolved against Astro.site (https://maxine.science).
const path = Astro.url.pathname.replace(/\/$/, '');
const ogPath = path === '' ? '/og/home.png' : `/og${path}.png`;
const ogUrl = new URL(ogPath, Astro.site ?? Astro.url.origin).toString();
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();

const themeColor = theme === 'dial' ? '#0a0b12' : '#2e1420';
const ogImageAlt = imageAlt ?? `Open graph card for ${title} — ${SITE}.`;

// Convert frontmatter human dates ("January 3, 2023") to ISO calendar
// dates for article:published_time. JS Date parses these reliably.
let publishedISO: string | undefined;
if (published) {
  const d = new Date(published);
  if (!Number.isNaN(d.getTime())) {
    publishedISO = d.toISOString().slice(0, 10);
  }
}
---
<!DOCTYPE html>
<html lang="en" data-theme={theme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content={themeColor} />
  <title>{pageTitle}</title>

  <!-- Favicon (rendered double-pendulum trace, see src/pages/favicon.svg.ts) -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph / Twitter -->
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={SITE} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={ogUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:alt" content={ogImageAlt} />
  {ogType === 'article' && author && <meta property="article:author" content={author} />}
  {ogType === 'article' && publishedISO && <meta property="article:published_time" content={publishedISO} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogUrl} />
  <meta name="twitter:image:alt" content={ogImageAlt} />

  <link rel="canonical" href={canonical} />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&display=swap" />
  <!-- KaTeX for math rendering -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
